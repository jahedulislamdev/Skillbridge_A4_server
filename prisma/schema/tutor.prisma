// tutorsProfile
model Tutor {
  id              String      @id @default(uuid())
  userId          String      @unique //FK
  user            User        @relation(fields: [userId], references: [id])
  bio             String      @db.VarChar(225)
  hourlyRate      Decimal     @db.Decimal(10, 2)
  experienceYears Int         @default(0)
  averageRating   Float       @default(0)
  status          TutomStatus @default(PENDING)
  totalReviews    Int         @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  tutorSubjects     TutorSubject[]
  availabilitySlots AvailabilitySlot[]
  reviews           Review[]           @relation("TutorReviews")
  booking           Booking[]          @relation("TutorBookings")

  @@index([hourlyRate], name: "idx_tutor_hourlyRate")
  @@index([status], name:"idx_tutor_bookingStatus")
  @@map("tutorsprofile")
}

enum TutomStatus {
  APPROVED
  PENDING
}
