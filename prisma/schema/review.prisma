// user review
model Review {
  id        String  @id @default(uuid())
  bookingId String  @unique //FK
  booking   Booking @relation(fields: [bookingId], references: [id])
  studentId String //FK
  student   User    @relation("StudentReviews", fields: [studentId], references: [id])
  tutorId   String //FK
  tutor     Tutor   @relation("TutorReviews", fields: [tutorId], references: [id])

  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  @@index([bookingId])
  @@index([studentId])
  @@map("reviews")
}
